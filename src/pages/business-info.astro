---
import Layout from '../layouts/Layout.astro';
import content from '../data/content.json';
const { brand } = content;
---

<Layout
  title="Business Information – SiteForge"
  description="Business information for SiteForge."
  noindex={true}
>

<!-- Nav -->
<header class="fixed top-0 left-0 right-0 z-50">
  <div class="mx-4 mt-3 rounded-2xl bg-[#0A0F1E]/80 backdrop-blur-xl border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.4)]">
    <div class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5" aria-label="SiteForge home">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-brand to-brand-cyan flex items-center justify-center">
          <span class="text-white font-bold text-xs font-display">S</span>
        </div>
        <span class="font-display font-bold text-base text-white tracking-wide">{brand.name}</span>
      </a>
    </div>
  </div>
</header>

<!-- Content -->
<main class="bg-white min-h-screen flex items-center justify-center px-6">
  <div class="w-full max-w-sm">

    <!-- Icon -->
    <div class="w-16 h-16 rounded-full bg-brand/10 flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
    </div>

    <h1 class="text-2xl font-display font-bold text-ink text-center mb-2">Business Information</h1>
    <p class="text-ink/40 text-sm text-center mb-8">For verification purposes only.</p>

    <!-- Data card -->
    <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm mb-6">
      <div class="px-5 py-4 border-b border-gray-50">
        <p class="text-xs font-semibold text-ink/30 uppercase tracking-widest mb-1">Owner</p>
        <p class="text-sm font-medium text-ink">Rok Kašpar</p>
      </div>
      <div class="px-5 py-4 border-b border-gray-50">
        <p class="text-xs font-semibold text-ink/30 uppercase tracking-widest mb-1">Business Name</p>
        <p class="text-sm font-medium text-ink">Kamnoseštvo, Rok Kašpar s.p.</p>
      </div>
      <div class="px-5 py-4 border-b border-gray-50">
        <p class="text-xs font-semibold text-ink/30 uppercase tracking-widest mb-1">Address</p>
        <p class="text-sm font-medium text-ink">Na Kalu 16, 4202 Naklo</p>
      </div>
      <div class="px-5 py-4 border-b border-gray-50">
        <p class="text-xs font-semibold text-ink/30 uppercase tracking-widest mb-1">Tax ID (Davčna številka)</p>
        <p class="text-sm font-medium text-ink">94827290</p>
      </div>
      <div class="px-5 py-4">
        <p class="text-xs font-semibold text-ink/30 uppercase tracking-widest mb-1">Country</p>
        <p class="text-sm font-medium text-ink">Slovenia</p>
      </div>
    </div>

    <a
      href="/"
      class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-brand text-white font-semibold text-sm hover:bg-brand-dark transition-colors"
    >
      ← Back to home
    </a>

  </div>
</main>

</Layout>
