---
const { comparison } = Astro.props;
const siteforgeIndex = 2;
const agencyIndex = 0;
---

<section class="py-24 bg-gray-50 relative overflow-hidden">
  <div class="max-w-5xl mx-auto px-6">

    <div class="text-center mb-14" data-aos="fade-up">
      <p class="text-xs font-semibold text-brand tracking-widest uppercase mb-3">Comparison</p>
      <h2 class="font-display font-bold text-gray-900 tracking-tight mb-4" style="font-size: clamp(1.9rem, 4vw, 2.75rem);">
        {comparison.title}
      </h2>
    </div>

    <div data-aos="fade-up" data-aos-delay="100">

      <!-- MOBILE: 2 columns only (Agency + SiteForge) -->
      <div class="block md:hidden">
        <div class="grid grid-cols-[1fr_1fr_1fr] gap-2 mb-2">
          <div></div>
          <div class="rounded-t-2xl px-3 py-4 text-center bg-white border border-gray-100">
            <div class="font-display font-bold text-sm text-gray-700">{comparison.columns[0]}</div>
          </div>
          <div class="rounded-t-2xl px-3 py-4 text-center bg-brand">
            <div class="text-blue-200 text-[10px] font-medium mb-0.5">Best value</div>
            <div class="font-display font-bold text-sm text-white">{comparison.columns[2]}</div>
          </div>
        </div>
        <div class="rounded-b-2xl overflow-hidden border border-gray-100 bg-white">
          {comparison.rows.map((row: any, ri: number) => (
            <div class={`grid grid-cols-[1fr_1fr_1fr] gap-0 ${ri < comparison.rows.length - 1 ? 'border-b border-gray-50' : ''}`}>
              <div class={`px-3 py-3.5 text-xs font-semibold text-gray-600 ${ri % 2 === 0 ? 'bg-gray-50/50' : 'bg-white'}`}>
                {row.label}
              </div>
              <div class={`px-3 py-3.5 text-xs text-center text-gray-400 ${ri % 2 === 0 ? 'bg-gray-50/50' : 'bg-white'}`}>
                {row.values[0]}
              </div>
              <div class="px-3 py-3.5 text-xs text-center bg-brand/5 font-semibold text-brand border-x border-brand/10">
                <span class="inline-flex items-center gap-1">
                  <svg class="w-3 h-3 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {row.values[2]}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- DESKTOP: all 3 columns -->
      <div class="hidden md:block overflow-x-auto">
        <div class="min-w-[560px]">
          <div class="grid grid-cols-[1.2fr_1fr_1fr_1fr] gap-2 mb-2">
            <div></div>
            {comparison.columns.map((col: string, i: number) => (
              <div class={`rounded-t-2xl px-5 py-4 text-center ${i === siteforgeIndex ? 'bg-brand text-white' : 'bg-white border border-gray-100 text-gray-500'}`}>
                {i === siteforgeIndex && (
                  <div class="text-blue-200 text-xs font-medium mb-1">Recommended</div>
                )}
                <div class={`font-display font-bold text-base ${i === siteforgeIndex ? 'text-white' : 'text-gray-700'}`}>{col}</div>
              </div>
            ))}
          </div>
          <div class="rounded-b-2xl overflow-hidden border border-gray-100 bg-white">
            {comparison.rows.map((row: any, ri: number) => (
              <div class={`grid grid-cols-[1.2fr_1fr_1fr_1fr] gap-0 ${ri < comparison.rows.length - 1 ? 'border-b border-gray-50' : ''}`}>
                <div class={`px-5 py-4 text-sm font-semibold text-gray-600 ${ri % 2 === 0 ? 'bg-gray-50/50' : 'bg-white'}`}>
                  {row.label}
                </div>
                {row.values.map((val: string, vi: number) => (
                  <div class={`px-5 py-4 text-sm text-center ${
                    vi === siteforgeIndex
                      ? 'bg-brand/5 font-semibold text-brand border-x border-brand/10'
                      : ri % 2 === 0 ? 'bg-gray-50/50 text-gray-400' : 'bg-white text-gray-400'
                  }`}>
                    {vi === siteforgeIndex ? (
                      <span class="inline-flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {val}
                      </span>
                    ) : val}
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
