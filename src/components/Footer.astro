---
const { footer, brand } = Astro.props;
---

<footer class="bg-[#070C18] border-t border-white/6">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Main grid -->
    <div class="py-16 grid md:grid-cols-[1.8fr_1fr_1fr_1.8fr] gap-10 border-b border-white/6">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-brand to-brand-cyan flex items-center justify-center flex-shrink-0">
            <span class="text-white font-bold text-xs font-display">S</span>
          </div>
          <span class="font-display font-bold text-white text-base tracking-wide">{brand.name}</span>
          <p class="text-white/30 text-xs mt-1 leading-snug max-w-[180px]">{footer.tagline}</p>
        </div>
        <p class="text-white/35 text-sm leading-relaxed max-w-xs">
          Simple, professional websites for local service businesses. Delivered in days, not months.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-white/60 text-xs font-semibold uppercase tracking-wider mb-5">Product</h3>
        <ul class="space-y-3.5">
          <li><a href="#demos" class="text-white/35 hover:text-white text-sm transition-colors">Examples</a></li>
          <li><a href="#pricing" class="text-white/35 hover:text-white text-sm transition-colors">Pricing</a></li>
          <li><a href="#faq" class="text-white/35 hover:text-white text-sm transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-white/60 text-xs font-semibold uppercase tracking-wider mb-5">Legal</h3>
        <ul class="space-y-3.5">
          {footer.links.map((link: any) => (
            <li>
              <a href={link.href} class="text-white/35 hover:text-white text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact form -->
      <div>
        <h3 class="text-white/60 text-xs font-semibold uppercase tracking-wider mb-5">Contact</h3>
        <p class="text-white/30 text-xs mb-4">Have a question? Send us a message.</p>
        <form
          action={`https://formsubmit.co/${brand.formEndpoint}`}
          method="POST"
          class="space-y-2.5"
        >
          <input type="hidden" name="_subject" value="SiteForge website inquiry" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://siteforgeonline.com/thank-you" />
          <input
            type="text"
            name="name"
            placeholder="Your name"
            required
            class="w-full px-3.5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder-white/25 focus:outline-none focus:border-brand/50 focus:bg-white/8 transition-all"
          />
          <input
            type="email"
            name="email"
            placeholder="Email address"
            required
            class="w-full px-3.5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder-white/25 focus:outline-none focus:border-brand/50 transition-all"
          />
          <textarea
            name="message"
            placeholder="Your message"
            rows="2"
            required
            class="w-full px-3.5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder-white/25 focus:outline-none focus:border-brand/50 transition-all resize-none"
          ></textarea>
          <button
            type="submit"
            class="w-full px-4 py-2.5 rounded-xl bg-brand text-white text-sm font-semibold hover:bg-brand-dark transition-colors"
          >
            Send message
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/20 text-xs">
        © <span id="footer-year"></span> {brand.name}. All rights reserved.
      </p>
      <p class="text-white/15 text-xs">
        Professional websites for local service businesses.
      </p>
    </div>
  </div>
</footer>

<script is:inline>
  var el = document.getElementById('footer-year');
  if (el) el.textContent = new Date().getFullYear();
</script>
