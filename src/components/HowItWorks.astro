---
const { howItWorks } = Astro.props;

const stepIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
];
---

<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16" data-aos="fade-up">
      <div>
        <p class="text-xs font-semibold text-brand tracking-widest uppercase mb-3">Process</p>
        <h2 class="font-display font-bold text-gray-900 tracking-tight leading-tight" style="font-size: clamp(1.9rem, 4vw, 2.75rem);">
          How it works
        </h2>
      </div>
      <p class="text-gray-500 text-sm max-w-xs md:text-right">{howItWorks.supportingLine}</p>
    </div>

    <div class="relative">
      <div class="hidden lg:block absolute top-16 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px" aria-hidden="true">
        <div class="w-full h-full border-t-2 border-dashed border-gray-200"></div>
        <div class="absolute left-1/3 top-1/2 -translate-y-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-brand/30"></div>
        <div class="absolute left-2/3 top-1/2 -translate-y-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-brand/30"></div>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">
        {howItWorks.steps.map((step: any, i: number) => (
          <div class="group relative" data-aos="fade-up" data-aos-delay={i * 120}>
            <div class="relative bg-white rounded-3xl p-8 border border-gray-100 hover:border-brand/20 hover:shadow-[0_20px_60px_-15px_rgba(59,130,246,0.12)] transition-all duration-400 h-full">
              <div class="flex items-center gap-4 mb-7">
                <div class="relative flex-shrink-0 w-14 h-14 rounded-2xl bg-brand/8 flex items-center justify-center group-hover:bg-brand/12 transition-colors">
                  <div class="w-6 h-6 text-brand">
                    <Fragment set:html={stepIcons[i]} />
                  </div>
                  <div class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-brand text-white text-xs font-bold font-display flex items-center justify-center shadow-glow-sm">
                    {i + 1}
                  </div>
                </div>
                <div class="flex-1 h-px bg-gradient-to-r from-gray-100 to-transparent"></div>
              </div>
              <h3 class="font-display font-bold text-gray-900 text-xl mb-3 leading-snug">{step.title}</h3>
              <p class="text-gray-500 text-base leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
