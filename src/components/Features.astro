---
const { features } = Astro.props;

const svgIcons: Record<string, string> = {
  "📱": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r="1" fill="currentColor"/></svg>`,
  "⚡": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  "🔍": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>`,
  "🔒": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
  "🚀": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/></svg>`,
  "💰": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
};

const accents = [
  { bg: 'bg-blue-50', icon: 'text-blue-500', border: 'border-blue-100', num: 'text-blue-100' },
  { bg: 'bg-indigo-50', icon: 'text-indigo-500', border: 'border-indigo-100', num: 'text-indigo-100' },
  { bg: 'bg-cyan-50', icon: 'text-cyan-600', border: 'border-cyan-100', num: 'text-cyan-100' },
  { bg: 'bg-slate-50', icon: 'text-slate-500', border: 'border-slate-100', num: 'text-slate-100' },
  { bg: 'bg-violet-50', icon: 'text-violet-500', border: 'border-violet-100', num: 'text-violet-100' },
  { bg: 'bg-sky-50', icon: 'text-sky-500', border: 'border-sky-100', num: 'text-sky-100' },
];
---

<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14" data-aos="fade-up">
      <div>
        <p class="text-xs font-semibold text-brand tracking-widest uppercase mb-3">What's included</p>
        <h2 class="font-display font-bold text-gray-900 tracking-tight leading-tight" style="font-size: clamp(1.9rem, 4vw, 2.75rem);">
          Everything you need.<br/>Nothing you don't.
        </h2>
      </div>
      <p class="text-gray-500 text-base max-w-xs md:text-right">
        Built for local service businesses. No bloat, no complexity.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
      {features.map((feature: any, i: number) => {
        const a = accents[i % accents.length];
        return (
          <div
            class={`group relative rounded-3xl p-5 sm:p-8 border ${a.bg} ${a.border} hover:scale-[1.02] transition-all duration-300 overflow-hidden`}
            data-aos="fade-up"
            data-aos-delay={i * 60}
          >
            <span class={`absolute -right-2 -bottom-4 font-display font-bold text-[5rem] sm:text-[7rem] leading-none select-none pointer-events-none ${a.num} transition-transform duration-500 group-hover:scale-110 group-hover:-translate-y-1`} aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class={`relative w-11 h-11 ${a.icon} mb-6`}>
              <Fragment set:html={svgIcons[feature.icon] ?? svgIcons['⚡']} />
            </div>
            <h3 class="relative font-display font-bold text-gray-900 text-xl mb-2 leading-snug">{feature.title}</h3>
            <p class="relative text-gray-500 text-sm leading-relaxed max-w-[220px]">{feature.description}</p>
          </div>
        );
      })}
    </div>

  </div>
</section>
