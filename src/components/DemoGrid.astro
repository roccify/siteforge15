---
const { demos } = Astro.props;
---

<section id="demos" class="py-24 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12" data-aos="fade-up">
      <div>
        <p class="text-xs font-semibold text-brand tracking-widest uppercase mb-3">Portfolio</p>
        <h2 class="font-display font-bold text-gray-900 tracking-tight" style="font-size: clamp(1.9rem, 4vw, 2.75rem);">
          Example websites
        </h2>
      </div>
      <p class="text-gray-500 text-sm max-w-xs md:text-right">
        Example designs for local service businesses across different industries.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {demos.map((demo: any, i: number) => (
        <div
          class="group bg-white rounded-3xl overflow-hidden border border-gray-100 hover:border-brand/20 hover:shadow-[0_20px_60px_-15px_rgba(59,130,246,0.15)] transition-all duration-300"
          data-aos="fade-up"
          data-aos-delay={i * 80}
        >
          <!-- Browser chrome -->
          <div class="bg-gray-100 px-4 py-2.5 flex items-center gap-2 border-b border-gray-200">
            <div class="flex gap-1.5" aria-hidden="true">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
            </div>
            <div class="flex-1 bg-white rounded px-2 py-1 text-[10px] text-gray-400 truncate border border-gray-200">
            </div>
          </div>

          <!-- Screenshot -->
          <div class="aspect-[16/10] overflow-hidden relative">
            <img
              src={demo.thumbnail}
              alt={`${demo.company} website`}
              class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-500"
              loading="lazy"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-brand/0 group-hover:bg-brand/5 transition-colors duration-300"></div>
          </div>

          <!-- Card footer -->
          <div class="px-5 py-4 flex items-center justify-between">
            <div>
              <p class="font-semibold text-gray-900 text-base">{demo.company}</p>
              <span class="inline-flex items-center mt-1 px-2 py-0.5 rounded-full bg-brand/8 text-brand text-xs font-medium">
                {demo.vertical}
              </span>
            </div>
            <a
              href={demo.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:text-brand-dark transition-colors group/link"
            >
              View demo
              <svg class="w-3.5 h-3.5 group-hover/link:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
